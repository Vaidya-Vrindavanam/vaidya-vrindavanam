---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/CTABanner.astro';
import { getTreatments } from '../../lib/sanity';
import type { Treatment } from '../../lib/sanity';

export async function getStaticPaths() {
  const treatments = await getTreatments();
  return treatments.map(treatment => ({
    params: { slug: treatment.slug },
    props: { treatment },
  }));
}

const { treatment } = Astro.props as { treatment: Treatment };

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalTherapy",
      "name": treatment.name,
      "description": treatment.shortDescription,
      "provider": {
        "@type": "MedicalBusiness",
        "name": "Vaidya Vrindavanam Ayurveda Hospital",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Haripad",
          "addressRegion": "Kerala",
          "addressCountry": "IN"
        }
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://vaidyavrindavanam.com" },
        { "@type": "ListItem", "position": 2, "name": "Treatments", "item": "https://vaidyavrindavanam.com/treatments" },
        { "@type": "ListItem", "position": 3, "name": treatment.name, "item": `https://vaidyavrindavanam.com/treatments/${treatment.slug}` }
      ]
    }
  ]
};
---

<BaseLayout
  title={`${treatment.name} Treatment`}
  description={`${treatment.shortDescription}. Available at Vaidya Vrindavanam Ayurveda Hospital, Haripad, Kerala. Book via WhatsApp.`}
  schema={schema}
>
  {treatment.imageUrl && (
    <div class="w-full" style="max-height: 480px; overflow: hidden;">
      <img
        src={treatment.imageUrl}
        alt={`${treatment.name} treatment at Vaidya Vrindavanam`}
        class="w-full object-cover"
        style="max-height: 480px; object-position: center;"
      />
    </div>
  )}

  <section class="py-12 px-6 bg-gradient-to-b from-brand-bg-alt to-brand-bg text-center">
    <p class="text-[9px] tracking-[5px] uppercase text-brand-gold mb-4">{treatment.category.replace(/-/g, ' ')}</p>
    <h1 class="text-3xl md:text-4xl font-display font-light text-text-primary tracking-wide">{treatment.name}</h1>
    {treatment.malayalam && (
      <p class="text-sm text-text-muted mt-2">{treatment.malayalam}</p>
    )}
    <div class="w-8 h-px bg-brand-gold mx-auto mt-5"></div>
    {treatment.duration && (
      <p class="text-xs text-text-muted mt-4">Duration: {treatment.duration}</p>
    )}
  </section>

  <section class="py-12 px-6 bg-brand-bg">
    <div class="max-w-3xl mx-auto prose prose-invert prose-sm prose-headings:font-display prose-headings:text-brand-gold prose-headings:font-light prose-headings:tracking-wide prose-p:text-text-secondary prose-p:leading-relaxed prose-li:text-text-secondary prose-strong:text-text-primary prose-a:text-brand-gold prose-a:no-underline">
      <div set:html={treatment.contentHTML}></div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
