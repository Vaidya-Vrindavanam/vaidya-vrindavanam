---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TreatmentCard from '../../components/TreatmentCard.astro';
import CTABanner from '../../components/CTABanner.astro';
import { getConditions, getTreatments } from '../../lib/sanity';
import type { Condition, Treatment } from '../../lib/sanity';
export async function getStaticPaths() {
  const [conditions, allTreatments] = await Promise.all([
    getConditions(),
    getTreatments(),
  ]);
  return conditions.map(condition => ({
    params: { slug: condition.slug },
    props: { condition, allTreatments },
  }));
}

const { condition, allTreatments } = Astro.props as { condition: Condition; allTreatments: Treatment[] };

const relatedTreatments = allTreatments.filter(t =>
  condition.treatments.some(cs => cs.slug === t.slug)
);

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalCondition",
      "name": condition.name,
      "description": condition.shortDescription,
      "possibleTreatment": relatedTreatments.map(t => ({
        "@type": "MedicalTherapy",
        "name": t.name,
      })),
      "relevantSpecialty": {
        "@type": "MedicalSpecialty",
        "name": "Ayurveda"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://vaidyavrindavanam.com" },
        { "@type": "ListItem", "position": 2, "name": "Conditions", "item": "https://vaidyavrindavanam.com/conditions" },
        { "@type": "ListItem", "position": 3, "name": condition.name, "item": `https://vaidyavrindavanam.com/conditions/${condition.slug}` }
      ]
    }
  ]
};
---

<BaseLayout
  title={`Ayurvedic Treatment for ${condition.name}`}
  description={`${condition.shortDescription}. Expert Ayurvedic care at Vaidya Vrindavanam, Haripad, Kerala.`}
  schema={schema}
>
  <section class="py-20 px-6 bg-gradient-to-b from-brand-bg-alt to-brand-bg text-center">
    <p class="text-[9px] tracking-[5px] uppercase text-brand-gold mb-3">Conditions We Treat</p>
    <h1 class="text-3xl md:text-4xl font-display font-light text-text-primary tracking-wide">{condition.name}</h1>
    <div class="w-8 h-px bg-brand-gold mx-auto mt-4"></div>
  </section>

  <section class="py-12 px-6 bg-brand-bg">
    <div class="max-w-3xl mx-auto prose prose-invert prose-sm prose-headings:font-display prose-headings:text-brand-gold prose-headings:font-light prose-headings:tracking-wide prose-p:text-text-secondary prose-p:leading-relaxed prose-li:text-text-secondary prose-strong:text-text-primary prose-a:text-brand-gold prose-a:no-underline">
      <div set:html={condition.contentHTML}></div>
    </div>
  </section>

  {relatedTreatments.length > 0 && (
    <section class="py-12 px-6 bg-brand-bg-alt">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-xl font-display text-brand-gold tracking-wide mb-6 text-center">Recommended Treatments</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {relatedTreatments.map(t => (
            <TreatmentCard name={t.name} description={t.shortDescription} imageUrl={t.imageUrl} slug={t.slug} />
          ))}
        </div>
      </div>
    </section>
  )}

  <CTABanner />
</BaseLayout>
