---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TreatmentCard from '../../components/TreatmentCard.astro';
import CTABanner from '../../components/CTABanner.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { getConditions, getTreatments } from '../../lib/sanity';
import type { Condition, Treatment } from '../../lib/sanity';
import { conditionDetails } from '../../data/conditionDetails';

export async function getStaticPaths() {
  const [conditions, allTreatments] = await Promise.all([
    getConditions(),
    getTreatments(),
  ]);
  return conditions.map(condition => ({
    params: { slug: condition.slug },
    props: { condition, allTreatments },
  }));
}

const { condition, allTreatments } = Astro.props as { condition: Condition; allTreatments: Treatment[] };

const relatedTreatments = allTreatments.filter(t =>
  condition.treatments.some(cs => cs.slug === t.slug)
);

const detail = conditionDetails[condition.slug];

const graph: Record<string, unknown>[] = [
  {
    "@type": "MedicalCondition",
    "name": condition.name,
    "description": condition.shortDescription,
    "possibleTreatment": relatedTreatments.map(t => ({
      "@type": "MedicalTherapy",
      "name": t.name,
      "url": `https://vaidyavrindavanam.com/treatments/${t.slug}/`,
    })),
    "relevantSpecialty": {
      "@type": "MedicalSpecialty",
      "name": "Ayurveda"
    }
  },
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://vaidyavrindavanam.com/" },
      { "@type": "ListItem", "position": 2, "name": "Conditions", "item": "https://vaidyavrindavanam.com/conditions/" },
      { "@type": "ListItem", "position": 3, "name": condition.name, "item": `https://vaidyavrindavanam.com/conditions/${condition.slug}/` }
    ]
  }
];

if (detail) {
  graph.push({
    "@type": "FAQPage",
    "mainEntity": detail.faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a,
      },
    })),
  });
}

const schema = {
  "@context": "https://schema.org",
  "@graph": graph,
};
---

<BaseLayout
  title={`Ayurveda for ${condition.name}`}
  description={`${condition.shortDescription} — Ayurvedic treatment at Vaidya Vrindavanam, Haripad, Kerala.`}
  schema={schema}
>
  <section class="py-20 px-6 bg-gradient-to-b from-brand-bg-alt to-brand-bg text-center">
    <p class="text-[9px] tracking-[5px] uppercase text-brand-gold mb-3">Conditions We Treat</p>
    <h1 class="text-3xl md:text-4xl font-display font-light text-text-primary tracking-wide">{condition.name}</h1>
    <div class="w-8 h-px bg-brand-gold mx-auto mt-4"></div>
  </section>

  {detail && (
    <>
      <section class="py-14 px-6 bg-brand-bg">
        <div class="max-w-3xl mx-auto">
          <p class="text-[9px] tracking-[5px] uppercase text-brand-gold mb-2">Overview</p>
          <h2 class="text-xl font-display font-light text-text-primary tracking-wide mb-6">{`Understanding ${condition.name}`}</h2>
          <p class="text-sm text-text-secondary leading-relaxed mb-8">{detail.overview}</p>
          <p class="text-[9px] tracking-[5px] uppercase text-brand-gold mt-10 mb-3">Common Symptoms</p>
          <ul class="space-y-2 text-sm text-text-secondary leading-relaxed list-disc pl-5 marker:text-brand-gold">
            {detail.symptoms.map(s => <li>{s}</li>)}
          </ul>
        </div>
      </section>

      <section class="py-14 px-6 bg-brand-bg-alt">
        <div class="max-w-3xl mx-auto">
          <p class="text-[9px] tracking-[5px] uppercase text-brand-gold mb-2">Ayurvedic Perspective</p>
          <h2 class="text-xl font-display font-light text-text-primary tracking-wide mb-6">The Classical View</h2>
          <p class="text-sm text-text-secondary leading-relaxed mb-10">{detail.ayurvedicView}</p>
          <p class="text-[9px] tracking-[5px] uppercase text-brand-gold mt-10 mb-3">Conventional vs Ayurvedic Approach</p>
          <p class="text-sm text-text-secondary leading-relaxed">{detail.approachComparison}</p>
        </div>
      </section>

      <section class="py-14 px-6 bg-brand-bg">
        <div class="max-w-3xl mx-auto">
          <p class="text-[9px] tracking-[5px] uppercase text-brand-gold mb-2">How We Treat</p>
          <h2 class="text-xl font-display font-light text-text-primary tracking-wide mb-8">Treatment Protocol</h2>
          <ol class="space-y-6">
            {detail.treatmentProtocol.map((p, i) => (
              <li class="border-l border-brand-gold-border pl-5">
                <div class="flex items-baseline gap-3 mb-1">
                  <span class="text-[9px] tracking-[4px] uppercase text-brand-gold shrink-0">Phase {i + 1}</span>
                  <span class="text-sm font-semibold text-text-primary">{p.phase}</span>
                </div>
                <p class="text-sm text-text-secondary leading-relaxed">{p.description}</p>
              </li>
            ))}
          </ol>
        </div>
      </section>

      <section class="py-14 px-6 bg-brand-bg-alt">
        <div class="max-w-3xl mx-auto">
          <p class="text-[9px] tracking-[5px] uppercase text-brand-gold mb-2">Expected Outcomes</p>
          <h2 class="text-xl font-display font-light text-text-primary tracking-wide mb-6">What Patients Can Expect</h2>
          <p class="text-sm text-text-secondary leading-relaxed">{detail.expectedOutcomes}</p>
        </div>
      </section>
    </>
  )}

  {condition.contentHTML && condition.contentHTML.trim() !== '' && (
    <section class="py-12 px-6 bg-brand-bg">
      <div class="max-w-3xl mx-auto prose prose-invert prose-sm prose-headings:font-display prose-headings:text-brand-gold prose-headings:font-light prose-headings:tracking-wide prose-p:text-text-secondary prose-p:leading-relaxed prose-li:text-text-secondary prose-strong:text-text-primary prose-a:text-brand-gold prose-a:no-underline">
        <div set:html={condition.contentHTML}></div>
      </div>
    </section>
  )}

  {relatedTreatments.length > 0 && (
    <section class="py-12 px-6 bg-brand-bg-alt">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-xl font-display text-brand-gold tracking-wide mb-6 text-center">Recommended Treatments</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {relatedTreatments.map(t => (
            <TreatmentCard name={t.name} description={t.shortDescription} imageUrl={t.imageUrl} slug={t.slug} />
          ))}
        </div>
      </div>
    </section>
  )}

  {detail && (
    <section class="py-14 px-6 bg-brand-bg">
      <div class="max-w-2xl mx-auto mb-8 text-center">
        <p class="text-[9px] tracking-[5px] uppercase text-brand-gold mb-2">Frequently Asked</p>
        <h2 class="text-xl font-display font-light text-text-primary tracking-wide">Questions Patients Ask</h2>
        <div class="w-8 h-px bg-brand-gold mx-auto mt-4"></div>
      </div>
      <FAQAccordion items={detail.faqs.map(f => ({ question: f.q, answer: f.a }))} />
    </section>
  )}

  <CTABanner />
</BaseLayout>
