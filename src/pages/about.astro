---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import DoctorProfile from '../components/DoctorProfile.astro';
import CTABanner from '../components/CTABanner.astro';
import { PHONE_PRIMARY_RAW } from '../config/contact';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalBusiness",
      "name": "Vaidya Vrindavanam Ayurveda Hospital",
      "url": "https://vaidyavrindavanam.com/",
      "image": "https://vaidyavrindavanam.com/og-default.jpg",
      "telephone": `+${PHONE_PRIMARY_RAW}`,
      "foundingDate": "2014",
      "sameAs": ["https://share.google/7sp4iCnGkZaIpZ53O"],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Near RK Junction, NH-66",
        "addressLocality": "Haripad",
        "addressRegion": "Kerala",
        "postalCode": "690514",
        "addressCountry": "IN"
      },
      "employee": [
        {
          "@type": "Person",
          "name": "Dr. Jayakrishnan T J",
          "jobTitle": "Consultant Physician & Founder",
          "description": "BAMS, MD (Ayurveda). 15 years of clinical experience. Specialises in Marma Chikitsa for chronic pain, neurological, and musculoskeletal conditions.",
          "image": "https://vaidyavrindavanam.com/dr-jayakrishnan.webp"
        },
        {
          "@type": "Person",
          "name": "Dr. Ganga SS",
          "jobTitle": "Consultant Physician",
          "description": "BAMS. 13 years of experience. Specialises in Prasooti and Stree Roga — women's health from adolescence through postnatal care.",
          "image": "https://vaidyavrindavanam.com/dr-ganga.webp"
        }
      ]
    }
  ]
};
---

<BaseLayout
  title="About Our Ayurveda Doctors & Clinic"
  description="Classical Ayurveda in Haripad since 2014. Meet Dr. Jayakrishnan (MD Ayurveda) and Dr. Ganga — personalised, prakriti-based care from experienced Kerala physicians."
  schema={schema}
>

  <!-- Hero -->
  <section class="py-20 px-6 bg-gradient-to-b from-brand-bg-alt to-brand-bg text-center">
    <p class="text-[9px] tracking-[5px] uppercase text-brand-gold mb-3">Est. 2014 · Haripad, Kerala</p>
    <h1 class="text-3xl md:text-4xl font-display font-light text-text-primary tracking-wide">
      Where Ayurveda Finds Its Root
    </h1>
    <div class="w-8 h-px bg-brand-gold mx-auto mt-4 mb-5"></div>
    <p class="text-sm text-text-secondary font-light max-w-md mx-auto leading-relaxed">
      Twelve years of classical healing in the heart of Kerala — unhurried, thorough, and rooted in ancient wisdom.
    </p>
  </section>

  <!-- Story -->
  <section class="py-16 px-6 bg-brand-bg">
    <div class="max-w-3xl mx-auto">
      <SectionHeader label="Our Story" heading="Born From a Calling, Built on Trust" />
      <div class="text-sm text-text-secondary leading-relaxed space-y-4 font-light">
        <p>
          In 2014, after completing his MD in Ayurveda from Alvas Ayurveda College, Moodbidri, Dr. Jayakrishnan T J made a deliberate choice. Rather than practise on someone else's terms, he wanted a space of his own — a place where every patient could receive unhurried, thorough care. Guided by the counsel of his mentor, Dr. J Hareendran Nair, he opened Vaidya Vrindavanam in Haripad.
        </p>
        <p>
          What began as a modest consulting practice grew, patient by patient, into a full-fledged hospital within two years. Today, twelve years on, Vaidya Vrindavanam serves patients from across Kerala, other Indian states, and overseas — all seeking the same thing: not a prescription, but a genuine cure.
        </p>
        <p>
          Our name says what we are. <strong class="text-brand-gold">Vaidya</strong> — healer. <strong class="text-brand-gold">Vrindavanam</strong> — a grove, a sacred space. Together, a place where ancient wisdom takes root and people find their way back to health.
        </p>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="py-16 px-6 bg-brand-bg-alt">
    <div class="max-w-3xl mx-auto">
      <SectionHeader label="Our Approach" heading="Classical Ayurveda, Exactly as It Was Meant" />
      <div class="text-sm text-text-secondary leading-relaxed space-y-4 font-light">
        <p>
          We practise classical Ayurveda — the kind documented in the ancient texts, undiluted by shortcuts. Every patient undergoes a thorough <strong class="text-text-primary">prakriti</strong> (mind-body constitution) assessment before a single treatment is planned. Your constitution guides everything: the medicines, the procedures, the diet.
        </p>
        <p>
          There is no rush here. We explain your condition, outline what treatment can and cannot do, and let you decide. When you are ready, we design a treatment structure together — and walk with you through every step of it.
        </p>
        <p>
          Our focus is the root cause. Not relief that lasts a week, but resolution that holds.
        </p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16 px-6 bg-brand-bg">
    <div class="max-w-4xl mx-auto">
      <SectionHeader label="What Guides Us" heading="Our Core Values" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="border border-brand-gold-border p-6">
          <h3 class="text-brand-gold font-display text-lg mb-2">Unhurried Attention</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Every consultation runs as long as it needs to. We do not move on until we have heard the full story — the condition, the context, the person behind it.
          </p>
        </div>
        <div class="border border-brand-gold-border p-6">
          <h3 class="text-brand-gold font-display text-lg mb-2">Prakriti-First Medicine</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Your constitution determines your treatment. No two patients receive the same care — medicines, therapies, and diet are tailored specifically to you.
          </p>
        </div>
        <div class="border border-brand-gold-border p-6">
          <h3 class="text-brand-gold font-display text-lg mb-2">Root Cause Resolution</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            We treat the cause, not just the complaint. Lasting healing sometimes takes longer — we are comfortable with that, and we make sure our patients are too.
          </p>
        </div>
        <div class="border border-brand-gold-border p-6">
          <h3 class="text-brand-gold font-display text-lg mb-2">Diet as Medicine</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Ayurveda has always held food as its first medicine. Dietary guidance is not an afterthought here — it is integral to every treatment plan we prepare.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Facility -->
  <section class="py-16 px-6 bg-brand-bg-alt">
    <div class="max-w-3xl mx-auto">
      <SectionHeader label="Our Facility" heading="A Space Built for Healing" />
      <div class="text-sm text-text-secondary leading-relaxed space-y-4 font-light">
        <p>
          Situated near RK Junction on NH-66 in Haripad, the hospital is easy to reach — 500 metres from the Haripad bus stand and one kilometre from the railway station. But what patients notice first is not the location.
        </p>
        <p>
          It is the feeling of the place: a garden, a pond, open air, and Kerala's green all around. The kind of environment where the body begins to settle before treatment has even started.
        </p>
        <p>
          For patients staying with us, we offer four private rooms, a dormitory, and a canteen that serves simple, sattvic meals — sometimes in an open hut, the way Kerala has always done it. Yoga and pranayama are available each morning. A small library is open to those who want quiet time.
        </p>
        <p>
          The hospital has 15 inpatient beds, two dedicated treatment rooms, and an in-house Ayurvedic dispensary. All medicines are dispensed on-site, sourced from trusted classical manufacturers.
        </p>
      </div>

      <!-- Facility highlights -->
      <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-4 text-center">
        {[
          { label: '15', sub: 'Patient Beds' },
          { label: '4+', sub: 'Accommodation Rooms' },
          { label: '12', sub: 'Years in Practice' },
          { label: '2', sub: 'Treatment Rooms' },
          { label: '2', sub: 'Qualified Doctors' },
          { label: '500m', sub: 'From Bus Stand' },
        ].map(({ label, sub }) => (
          <div class="border border-brand-gold-border py-4 px-3">
            <p class="font-display text-2xl font-light text-brand-gold">{label}</p>
            <p class="text-[10px] tracking-widest uppercase text-text-muted mt-1">{sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Doctors -->
  <section class="py-16 px-6 bg-brand-bg">
    <div class="max-w-4xl mx-auto">
      <SectionHeader label="Expert Care" heading="Our Physicians" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 max-w-2xl mx-auto">
        <div class="text-center">
          <DoctorProfile
            name="Dr. Jayakrishnan T J"
            qualification="BAMS, MD (Ayurveda)"
            title="Consultant Physician & Founder"
            image="/dr-jayakrishnan.webp"
          />
          <p class="text-sm text-text-secondary mt-4 leading-relaxed">
            Dr. Jayakrishnan founded Vaidya Vrindavanam in 2014 after completing his MD at Alvas Ayurveda College, Moodbidri. With 15 years of clinical experience, he specialises in <strong class="text-text-primary">Marma Chikitsa</strong> — the classical science of vital energy points — applied to chronic pain, neurological conditions, and musculoskeletal disorders. He personally oversees each patient's care from first consultation to discharge.
          </p>
        </div>
        <div class="text-center">
          <DoctorProfile
            name="Dr. Ganga SS"
            qualification="BAMS"
            title="Consultant Physician"
            image="/dr-ganga.webp"
          />
          <p class="text-sm text-text-secondary mt-4 leading-relaxed">
            Dr. Ganga brings 13 years of experience in classical Ayurvedic practice, with a specialisation in <strong class="text-text-primary">Prasooti and Stree Roga</strong> — women's health across all stages, from adolescence and fertility through pregnancy and postnatal recovery. Patients know her for her patience in listening and her precision in treatment.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Vision -->
  <section class="py-16 px-6 bg-brand-bg-alt">
    <div class="max-w-4xl mx-auto">
      <SectionHeader label="Looking Ahead" heading="Where We Are Going" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="border border-brand-gold-border p-6">
          <h3 class="text-brand-gold font-display text-lg mb-2">Panchakarma Destination</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Building Vaidya Vrindavanam into a premier destination for authentic Karkidaka Chikitsa and classical Panchakarma — for those who want the real Kerala experience.
          </p>
        </div>
        <div class="border border-brand-gold-border p-6">
          <h3 class="text-brand-gold font-display text-lg mb-2">Lifestyle Disease Reversal</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Structured programs for diabetes, hypertension, PCOS, and arthritis — conditions that modern medicine manages but Ayurveda can address at the root.
          </p>
        </div>
        <div class="border border-brand-gold-border p-6">
          <h3 class="text-brand-gold font-display text-lg mb-2">Mental Wellness through Ayurveda</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Expanding care for stress, insomnia, and anxiety — combining Shirodhara, sattvic lifestyle guidance, and personalised counselling into integrated treatment plans.
          </p>
        </div>
        <div class="border border-brand-gold-border p-6">
          <h3 class="text-brand-gold font-display text-lg mb-2">Women & Child Wellness</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Deepening our expertise in pre and postnatal care, fertility, and adolescent health — drawing on Kerala's traditional <em>Balachikitsa</em> and <em>Sthree Roga</em> lineage.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
