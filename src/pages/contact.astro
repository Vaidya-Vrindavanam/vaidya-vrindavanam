---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { PHONE_PRIMARY, PHONE_PRIMARY_RAW, PHONE_SECONDARY, PHONE_SECONDARY_RAW, EMAIL, WA_DEFAULT } from '../config/contact';

const faqs = [
  { question: 'What are your clinic hours?', answer: 'We are open Monday through Saturday. Morning: 9:00 AM – 12:00 PM. Evening: 4:00 PM – 7:00 PM. We are closed on Sundays for outpatient consultations, but inpatients receive care daily.' },
  { question: 'Do I need to book in advance?', answer: 'Walk-ins are welcome for regular consultations. However, for residential treatment packages, we recommend booking in advance to ensure availability.' },
  { question: 'How do I reach Vaidya Vrindavanam?', answer: 'We are located on NH-66 near RK Junction, Haripad. Haripad is well-connected by both road and rail. The Haripad railway station is nearby. Ample parking is available at the clinic.' },
  { question: 'Do you offer online consultations?', answer: `Yes, we offer online consultations via WhatsApp video call. Contact us on WhatsApp (${PHONE_PRIMARY}) to schedule a virtual appointment.` },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<BaseLayout
  title="Contact & Directions — Haripad, Kerala"
  description={`Visit or contact Vaidya Vrindavanam Ayurveda Hospital, near RK Junction, NH-66, Haripad, Alappuzha, Kerala. Call ${PHONE_PRIMARY} or WhatsApp us.`}
  schema={schema}
>
  <section class="py-20 px-6 bg-gradient-to-b from-brand-bg-alt to-brand-bg text-center">
    <p class="text-[9px] tracking-[5px] uppercase text-brand-gold mb-3">Get in Touch</p>
    <h1 class="text-3xl md:text-4xl font-display font-light text-text-primary tracking-wide">Contact Us</h1>
    <div class="w-8 h-px bg-brand-gold mx-auto mt-4"></div>
  </section>

  <section class="py-12 px-6 bg-brand-bg">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10">
      <!-- Contact info -->
      <div>
        <h2 class="text-xl font-display text-brand-gold tracking-wide mb-6">Visit Us</h2>
        <div class="space-y-4 text-sm text-text-secondary">
          <div>
            <p class="text-text-muted text-xs uppercase tracking-wider mb-1">Address</p>
            <p>Near RK Junction, NH-66<br />Haripad, Alappuzha - 690514<br />Kerala, India</p>
          </div>
          <div>
            <p class="text-text-muted text-xs uppercase tracking-wider mb-1">Phone</p>
            <p><a href={`tel:+${PHONE_PRIMARY_RAW}`} class="text-brand-gold hover:text-text-primary transition-colors">{PHONE_PRIMARY}</a></p>
            <p><a href={`tel:+${PHONE_SECONDARY_RAW}`} class="text-brand-gold hover:text-text-primary transition-colors">{PHONE_SECONDARY}</a></p>
          </div>
          <div>
            <p class="text-text-muted text-xs uppercase tracking-wider mb-1">Email</p>
            <p><a href={`mailto:${EMAIL}`} class="text-brand-gold hover:text-text-primary transition-colors">{EMAIL}</a></p>
          </div>
          <div>
            <p class="text-text-muted text-xs uppercase tracking-wider mb-1">Hours</p>
            <p>Mon–Sat: 9:00 AM – 12:00 PM &amp; 4:00 – 7:00 PM<br />Sunday: Closed (OP)</p>
          </div>
        </div>

        <div class="mt-8 flex gap-3 flex-wrap">
          <a
            href={WA_DEFAULT}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-brand-whatsapp text-white px-6 py-2.5 text-xs font-bold tracking-widest"
          >
            WHATSAPP
          </a>
          <a href={`tel:+${PHONE_PRIMARY_RAW}`} class="bg-brand-gold text-brand-bg px-6 py-2.5 text-xs font-bold tracking-widest">
            CALL
          </a>
        </div>
      </div>

      <!-- Contact form -->
      <div>
        <h2 class="text-xl font-display text-brand-gold tracking-wide mb-6">Send a Message</h2>
        <form action="https://formspree.io/f/mgoreanz" method="POST" class="space-y-4">
          <!-- Honeypot — hidden from real users, catches bots -->
          <input type="text" name="_honey" style="display:none" />
          <!-- Subject line in the notification email -->
          <input type="hidden" name="_subject" value="New Enquiry — Vaidya Vrindavanam" />

          <div>
            <label class="text-xs text-text-muted uppercase tracking-wider block mb-1" for="name">Your Name</label>
            <input type="text" id="name" name="name" required autocomplete="name" aria-describedby="name-error" class="w-full bg-brand-bg-alt border border-brand-gold-dim text-text-primary px-4 py-2.5 text-sm focus:border-brand-gold focus:outline-none" />
            <span id="name-error" class="text-xs text-red-400 mt-1 block" role="alert" hidden></span>
          </div>
          <div>
            <label class="text-xs text-text-muted uppercase tracking-wider block mb-1" for="phone">Phone / WhatsApp</label>
            <input type="tel" id="phone" name="phone" autocomplete="tel" aria-describedby="phone-error" class="w-full bg-brand-bg-alt border border-brand-gold-dim text-text-primary px-4 py-2.5 text-sm focus:border-brand-gold focus:outline-none" />
            <span id="phone-error" class="text-xs text-red-400 mt-1 block" role="alert" hidden></span>
          </div>
          <div>
            <!-- name="email" tells Formspree to use this as the reply-to address -->
            <label class="text-xs text-text-muted uppercase tracking-wider block mb-1" for="email">
              Email Address <span class="text-brand-gold normal-case tracking-normal">(required for overseas enquiries)</span>
            </label>
            <input type="email" id="email" name="email" autocomplete="email" aria-describedby="email-error" class="w-full bg-brand-bg-alt border border-brand-gold-dim text-text-primary px-4 py-2.5 text-sm focus:border-brand-gold focus:outline-none" />
            <span id="email-error" class="text-xs text-red-400 mt-1 block" role="alert" hidden></span>
          </div>
          <div>
            <label class="text-xs text-text-muted uppercase tracking-wider block mb-1" for="message">Message</label>
            <textarea id="message" name="message" rows="4" class="w-full bg-brand-bg-alt border border-brand-gold-dim text-text-primary px-4 py-2.5 text-sm focus:border-brand-gold focus:outline-none resize-none"></textarea>
          </div>
          <button type="submit" class="bg-brand-gold text-brand-bg px-6 py-2.5 text-xs font-bold tracking-widest w-full">
            SEND MESSAGE
          </button>
          <p class="text-xs text-text-subtle mt-3">
            Your information is processed securely via
            <a href="https://formspree.io/legal/privacy-policy" target="_blank" rel="noopener noreferrer" class="text-brand-gold underline">Formspree</a>
            and used only to respond to your enquiry. We do not share your data with third parties.
          </p>
        </form>
      </div>
    </div>
  </section>

  <!-- Google Maps -->
  <section class="bg-brand-bg-alt">
    <iframe
      src="https://www.google.com/maps?q=Vaidya+Vrindavanam+Ayurveda+Hospital+Haripad+Kerala&output=embed"
      title="Vaidya Vrindavanam Ayurveda Hospital location map"
      width="100%"
      height="400"
      style="display: block; border: none;"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </section>

  <script>
    (function () {
      const form = document.querySelector('form[action*="formspree"]');
      if (!form) return;

      const GOLD_DIM = 'var(--color-brand-gold-dim, #6b5a2e)';
      const ERROR_COLOR = '#f87171';

      function validate(id) {
        const field = form.querySelector('#' + id);
        if (!field) return '';
        const val = field.value.trim();

        if (id === 'name') {
          if (!val) return 'Please enter your name.';
        }
        if (id === 'phone') {
          if (val && !/^[+\d][\d\s\-()+]{5,}$/.test(val))
            return 'Please enter a valid phone number.';
        }
        if (id === 'email') {
          if (val && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val))
            return 'Please enter a valid email address.';
        }
        if (id === 'phone' || id === 'email') {
          const phone = (form.querySelector('#phone')).value.trim();
          const email = (form.querySelector('#email')).value.trim();
          if (!phone && !email)
            return 'Please provide at least a phone number or email address.';
        }
        return '';
      }

      function applyError(id, msg) {
        const field = form.querySelector('#' + id);
        const errEl = document.getElementById(id + '-error');
        if (!field || !errEl) return;
        errEl.textContent = msg;
        errEl.hidden = !msg;
        field.setAttribute('aria-invalid', msg ? 'true' : 'false');
        field.style.borderColor = msg ? ERROR_COLOR : '';
      }

      ['name', 'phone', 'email'].forEach(function (id) {
        const field = form.querySelector('#' + id);
        if (!field) return;
        field.addEventListener('blur', function () { applyError(id, validate(id)); });
        field.addEventListener('input', function () {
          if (field.getAttribute('aria-invalid') === 'true') applyError(id, validate(id));
        });
      });

      form.addEventListener('submit', function (e) {
        var blocked = false;
        ['name', 'phone', 'email'].forEach(function (id) {
          var msg = validate(id);
          applyError(id, msg);
          if (msg) blocked = true;
        });
        if (blocked) { e.preventDefault(); form.querySelector('[aria-invalid="true"]').focus(); }
      });
    })();
  </script>

  <!-- FAQ -->
  <section class="py-16 px-6 bg-brand-bg">
    <div class="max-w-4xl mx-auto">
      <SectionHeader label="Quick Answers" heading="Frequently Asked Questions" />
      <FAQAccordion items={faqs} />
    </div>
  </section>
</BaseLayout>
