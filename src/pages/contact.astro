---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const googleMapsApiKey = import.meta.env.GOOGLE_MAPS_API_KEY;

const faqs = [
  { question: 'What are your clinic hours?', answer: 'We are open Monday through Saturday. Morning: 9:00 AM – 12:00 PM. Evening: 4:00 PM – 7:00 PM. We are closed on Sundays for outpatient consultations, but inpatients receive care daily.' },
  { question: 'Do I need to book in advance?', answer: 'Walk-ins are welcome for regular consultations. However, for residential treatment packages, we recommend booking in advance to ensure availability.' },
  { question: 'How do I reach Vaidya Vrindavanam?', answer: 'We are located on NH-66 near RK Junction, Haripad. Haripad is well-connected by both road and rail. The Haripad railway station is nearby. Ample parking is available at the clinic.' },
  { question: 'Do you offer online consultations?', answer: 'Yes, we offer online consultations via WhatsApp video call. Contact us on WhatsApp (+91 90748 48705) to schedule a virtual appointment.' },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<BaseLayout
  title="Contact Us"
  description="Visit or contact Vaidya Vrindavanam Ayurveda Hospital, near RK Junction, NH-66, Haripad, Alappuzha, Kerala. Call +91 9074848705 or WhatsApp us."
  schema={schema}
>
  <section class="py-20 px-6 bg-gradient-to-b from-brand-bg-alt to-brand-bg text-center">
    <p class="text-[9px] tracking-[5px] uppercase text-brand-gold mb-3">Get in Touch</p>
    <h1 class="text-3xl md:text-4xl font-display font-light text-text-primary tracking-wide">Contact Us</h1>
    <div class="w-8 h-px bg-brand-gold mx-auto mt-4"></div>
  </section>

  <section class="py-12 px-6 bg-brand-bg">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10">
      <!-- Contact info -->
      <div>
        <h2 class="text-xl font-display text-brand-gold tracking-wide mb-6">Visit Us</h2>
        <div class="space-y-4 text-sm text-text-secondary">
          <div>
            <p class="text-text-muted text-xs uppercase tracking-wider mb-1">Address</p>
            <p>Near RK Junction, NH-66<br />Haripad, Alappuzha - 690514<br />Kerala, India</p>
          </div>
          <div>
            <p class="text-text-muted text-xs uppercase tracking-wider mb-1">Phone</p>
            <p><a href="tel:+919074848705" class="text-brand-gold hover:text-text-primary transition-colors">+91 90748 48705</a></p>
            <p><a href="tel:+918281861587" class="text-brand-gold hover:text-text-primary transition-colors">+91 82818 61587</a></p>
          </div>
          <div>
            <p class="text-text-muted text-xs uppercase tracking-wider mb-1">Email</p>
            <p><a href="mailto:ayurvv@gmail.com" class="text-brand-gold hover:text-text-primary transition-colors">ayurvv@gmail.com</a></p>
          </div>
          <div>
            <p class="text-text-muted text-xs uppercase tracking-wider mb-1">Hours</p>
            <p>Mon–Sat: 9:00 AM – 12:00 PM &amp; 4:00 – 7:00 PM<br />Sunday: Closed (OP)</p>
          </div>
        </div>

        <div class="mt-8 flex gap-3 flex-wrap">
          <a
            href="https://wa.me/919074848705?text=Hi%2C%20I%27d%20like%20to%20book%20an%20appointment%20at%20Vaidya%20Vrindavanam"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-brand-whatsapp text-white px-6 py-2.5 text-xs font-bold tracking-widest"
          >
            WHATSAPP
          </a>
          <a href="tel:+919074848705" class="bg-brand-gold text-brand-bg px-6 py-2.5 text-xs font-bold tracking-widest">
            CALL
          </a>
        </div>
      </div>

      <!-- Contact form -->
      <div>
        <h2 class="text-xl font-display text-brand-gold tracking-wide mb-6">Send a Message</h2>
        <form action="https://formspree.io/f/mgoreanz" method="POST" class="space-y-4">
          <div>
            <label class="text-xs text-text-muted uppercase tracking-wider block mb-1" for="name">Your Name</label>
            <input type="text" id="name" name="name" required class="w-full bg-brand-bg-alt border border-brand-gold-dim text-text-primary px-4 py-2.5 text-sm focus:border-brand-gold focus:outline-none" />
          </div>
          <div>
            <label class="text-xs text-text-muted uppercase tracking-wider block mb-1" for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone" required class="w-full bg-brand-bg-alt border border-brand-gold-dim text-text-primary px-4 py-2.5 text-sm focus:border-brand-gold focus:outline-none" />
          </div>
          <div>
            <label class="text-xs text-text-muted uppercase tracking-wider block mb-1" for="message">Message</label>
            <textarea id="message" name="message" rows="4" class="w-full bg-brand-bg-alt border border-brand-gold-dim text-text-primary px-4 py-2.5 text-sm focus:border-brand-gold focus:outline-none resize-none"></textarea>
          </div>
          <button type="submit" class="bg-brand-gold text-brand-bg px-6 py-2.5 text-xs font-bold tracking-widest w-full">
            SEND MESSAGE
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Google Maps -->
  <section class="bg-brand-bg-alt">
    <a
      href="https://www.google.com/maps/search/Vaidya+Vrindavanam,+Haripad,+Alappuzha/@12.1448,76.4079,15z"
      target="_blank"
      rel="noopener noreferrer"
      class="block"
      title="View Vaidya Vrindavanam on Google Maps"
    >
      <img
        src={`https://maps.googleapis.com/maps/api/staticmap?center=12.1448,76.4079&zoom=15&size=1200x400&style=feature:all|element:labels|visibility:off&style=feature:water|color:0x1a1a2e&style=feature:land|color:0x0f3c4d&style=feature:road|visibility:off&markers=color:0xd4af37|12.1448,76.4079&key=${googleMapsApiKey}`}
        alt="Map location of Vaidya Vrindavanam Ayurveda Hospital, Haripad, Alappuzha, Kerala"
        width="100%"
        height="400"
        style="display: block; width: 100%; height: 400px; object-fit: cover;"
      />
    </a>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-6 bg-brand-bg">
    <div class="max-w-4xl mx-auto">
      <SectionHeader label="Quick Answers" heading="Frequently Asked Questions" />
      <FAQAccordion items={faqs} />
    </div>
  </section>
</BaseLayout>
