---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatsBar from '../components/StatsBar.astro';
import SectionHeader from '../components/SectionHeader.astro';
import DoctorProfile from '../components/DoctorProfile.astro';
import TreatmentCard from '../components/TreatmentCard.astro';
import PackageCard from '../components/PackageCard.astro';
import ConditionTag from '../components/ConditionTag.astro';
import CTABanner from '../components/CTABanner.astro';
import { getTreatments, getConditions } from '../lib/sanity';

const treatments = (await getTreatments()).sort((a, b) => a.order - b.order);
const featuredTreatments = treatments.slice(0, 5);
const conditions = (await getConditions()).sort((a, b) => a.order - b.order);

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "name": "Vaidya Vrindavanam Ayurveda Hospital",
  "description": "Authentic Kerala Ayurveda hospital in Haripad offering Panchakarma, Marma Chikitsa, and 20+ traditional treatments with residential care.",
  "url": "https://vaidyavrindavanam.com",
  "telephone": "+919074848705",
  "email": "ayurvv@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Near RK Junction, NH-66",
    "addressLocality": "Haripad",
    "addressRegion": "Kerala",
    "postalCode": "690514",
    "addressCountry": "IN"
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      "opens": "09:00",
      "closes": "12:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      "opens": "16:00",
      "closes": "19:00"
    }
  ],
  "founder": {
    "@type": "Person",
    "name": "Dr. Jayakrishnan T J",
    "jobTitle": "Consultant Physician",
    "description": "BAMS, MD (Ayurveda)"
  }
};
---

<BaseLayout
  title="Authentic Kerala Ayurveda"
  description="Vaidya Vrindavanam Ayurveda Hospital in Haripad, Kerala — authentic Panchakarma, Marma Chikitsa with chiropractic care, 20+ treatments, residential packages. Book via WhatsApp."
  schema={schema}
>
  <!-- HERO -->
  <section class="relative bg-gradient-to-br from-brand-bg via-brand-bg-alt to-brand-bg min-h-[80vh] flex items-center justify-center text-center px-6 py-20">
    <div class="absolute top-10 left-1/2 -translate-x-1/2 text-[120px] opacity-[0.03] text-brand-gold select-none">☘</div>
    <div class="relative z-10 max-w-xl">
      <p class="text-[9px] tracking-[5px] uppercase text-brand-gold mb-4">Authentic Kerala Ayurveda · Est. 2014</p>
      <h1 class="text-4xl md:text-5xl font-display font-light text-text-primary leading-tight tracking-wide">
        Heal. Renew.<br /><em class="font-normal">Flourish.</em>
      </h1>
      <div class="w-10 h-px bg-brand-gold mx-auto my-6"></div>
      <p class="text-sm text-text-secondary leading-relaxed font-light max-w-md mx-auto">
        Where ancient Marma wisdom meets modern healing. Residential Panchakarma, personalised treatments, and holistic recovery in the heart of Kerala.
      </p>
      <div class="flex gap-3 justify-center mt-8 flex-wrap">
        <a
          href="https://wa.me/919074848705?text=Hi%2C%20I%27d%20like%20to%20book%20an%20appointment%20at%20Vaidya%20Vrindavanam"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-brand-gold text-brand-bg px-7 py-3 text-xs font-bold tracking-widest"
        >
          BOOK VIA WHATSAPP
        </a>
        <a href="/treatments" class="border border-brand-gold text-brand-gold px-7 py-3 text-xs tracking-widest hover:bg-brand-gold hover:text-brand-bg transition-colors">
          EXPLORE TREATMENTS
        </a>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <StatsBar />

  <!-- ABOUT + DOCTORS -->
  <section class="py-16 px-6 bg-brand-bg">
    <div class="max-w-4xl mx-auto">
      <SectionHeader label="About the Hospital" heading="A Legacy of Healing" />
      <p class="text-sm text-text-secondary leading-relaxed text-center max-w-2xl mx-auto mb-10 font-light">
        Since 2014, Vaidya Vrindavanam has been Haripad's trusted centre for authentic Ayurvedic healing.
        We uniquely combine traditional <strong class="text-brand-gold">Marma Chikitsa</strong> with
        <strong class="text-brand-gold">modern chiropractic treatment</strong> — alongside a full range
        of Panchakarma therapies, residential care, and an in-house dispensary.
      </p>
      <div class="flex gap-10 justify-center flex-wrap">
        <DoctorProfile name="Dr. Jayakrishnan T J" qualification="BAMS, MD (Ayurveda)" title="Consultant Physician" image="/dr-jayakrishnan.jpg" />
        <DoctorProfile name="Dr. Ganga SS" qualification="BAMS" title="Consultant Physician" image="/dr-ganga.jpg" />
      </div>
      <div class="text-center mt-8">
        <a href="/about" class="text-brand-gold text-xs tracking-widest hover:text-text-primary transition-colors">LEARN MORE ABOUT US →</a>
      </div>
    </div>
  </section>

  <!-- TREATMENTS + CONDITIONS -->
  <section class="py-16 px-6 bg-brand-bg-alt">
    <div class="max-w-4xl mx-auto">
      <SectionHeader label="Treatments & Conditions" heading="Our Healing Therapies" subtitle="Authentic Panchakarma & Kerala Ayurvedic treatments" />
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-10">
        {featuredTreatments.map(t => (
          <TreatmentCard name={t.name} description={t.shortDescription} icon={t.icon} slug={t.slug} />
        ))}
        <a href="/treatments" class="bg-brand-gold/10 border border-brand-gold-border p-5 text-center flex flex-col items-center justify-center hover:border-brand-gold transition-colors">
          <div class="text-2xl font-display font-light text-brand-gold">{treatments.length - 5}+</div>
          <div class="text-xs text-brand-gold mt-1">View All Treatments →</div>
        </a>
      </div>

      <div class="text-center">
        <p class="text-[9px] tracking-[2px] uppercase text-text-muted mb-4">Conditions We Specialise In</p>
        <div class="flex flex-wrap gap-2 justify-center">
          {conditions.map(c => (
            <ConditionTag name={c.name} slug={c.slug} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PACKAGES -->
  <section class="py-16 px-6 bg-brand-bg">
    <div class="max-w-4xl mx-auto">
      <SectionHeader label="Residential Programs" heading="Healing Packages" subtitle="With accommodation & full board" />
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <PackageCard name="Rejuvenation" duration="7 – 14 days" price="₹ Contact for pricing" popular={true} whatsappMessage="Hi, I'm interested in the Rejuvenation package. Please share details and pricing." />
        <PackageCard name="Detox" duration="7 – 21 days" price="₹ Contact for pricing" whatsappMessage="Hi, I'm interested in the Detox package. Please share details and pricing." />
        <PackageCard name="Weight Loss" duration="21 – 45 days" price="₹ Contact for pricing" whatsappMessage="Hi, I'm interested in the Weight Loss package. Please share details and pricing." />
        <PackageCard name="Relaxation" duration="10 – 20 days" price="₹ Contact for pricing" whatsappMessage="Hi, I'm interested in the Relaxation package. Please share details and pricing." />
      </div>
      <div class="text-center mt-6">
        <a href="/packages" class="text-brand-gold text-xs tracking-widest hover:text-text-primary transition-colors">VIEW ALL PACKAGES →</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="py-16 px-6 bg-brand-bg-alt">
    <div class="max-w-4xl mx-auto">
      <SectionHeader label="Patient Stories" heading="Voices of Healing" />

      <!-- Google Rating Summary -->
      <div class="flex items-center justify-center gap-3 mb-10">
        <span class="font-display text-4xl font-light text-brand-gold">4.2</span>
        <div>
          <div class="flex gap-0.5">
            {[1,2,3,4].map(() => (
              <svg width="16" height="16" viewBox="0 0 20 20" class="fill-brand-gold" xmlns="http://www.w3.org/2000/svg"><path d="M10 1l2.39 4.84 5.34.78-3.86 3.76.91 5.32L10 13.27l-4.78 2.51.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
            ))}
            <svg width="16" height="16" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <defs><linearGradient id="half"><stop offset="42%" stop-color="var(--color-gold)"/><stop offset="42%" stop-color="var(--color-gold)" stop-opacity="0.2"/></linearGradient></defs>
              <path d="M10 1l2.39 4.84 5.34.78-3.86 3.76.91 5.32L10 13.27l-4.78 2.51.91-5.32L2.27 6.62l5.34-.78L10 1z" fill="url(#half)"/>
            </svg>
          </div>
          <p class="text-[10px] tracking-[3px] uppercase text-text-muted mt-1">5 Google Reviews</p>
        </div>
      </div>

      <!-- Review Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 max-w-2xl mx-auto">

        <!-- Review 1 -->
        <div class="border border-brand-gold-border bg-brand-bg p-6">
          <div class="flex gap-0.5 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg width="13" height="13" viewBox="0 0 20 20" class="fill-brand-gold" xmlns="http://www.w3.org/2000/svg"><path d="M10 1l2.39 4.84 5.34.78-3.86 3.76.91 5.32L10 13.27l-4.78 2.51.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
            ))}
          </div>
          <p class="text-sm text-text-secondary italic leading-relaxed font-light">"Very good — a genuinely positive experience at the clinic."</p>
          <div class="mt-4 pt-4 border-t border-brand-gold-border flex items-center justify-between">
            <span class="text-xs text-text-primary font-body">Shephy Rustham</span>
            <span class="text-[10px] text-text-subtle tracking-wider">Google Review</span>
          </div>
        </div>

        <!-- Review 2 -->
        <div class="border border-brand-gold-border bg-brand-bg p-6">
          <div class="flex gap-0.5 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg width="13" height="13" viewBox="0 0 20 20" class="fill-brand-gold" xmlns="http://www.w3.org/2000/svg"><path d="M10 1l2.39 4.84 5.34.78-3.86 3.76.91 5.32L10 13.27l-4.78 2.51.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
            ))}
          </div>
          <p class="text-sm text-text-secondary italic leading-relaxed font-light">"A trusted Ayurvedic clinic in Haripad — recommended for anyone seeking authentic treatment."</p>
          <div class="mt-4 pt-4 border-t border-brand-gold-border flex items-center justify-between">
            <span class="text-xs text-text-primary font-body">Karundas Das</span>
            <span class="text-[10px] text-text-subtle tracking-wider">Google Review</span>
          </div>
        </div>

      </div>

      <!-- Link to Google -->
      <div class="text-center mt-8">
        <a
          href="https://www.google.com/maps/place/Vaidya+Vrindavanam+Ayurveda+Hospital+Haripad/@9.2711918,76.4608952,17z"
          target="_blank"
          rel="noopener noreferrer"
          class="text-brand-gold text-xs tracking-widest hover:text-text-primary transition-colors"
        >READ ALL REVIEWS ON GOOGLE →</a>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <CTABanner />
</BaseLayout>
