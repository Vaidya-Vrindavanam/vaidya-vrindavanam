---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getBlogPosts } from '../../lib/sanity';
import type { BlogPost } from '../../lib/sanity';
import { PHONE_PRIMARY_RAW } from '../../config/contact';

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: BlogPost };

const waMessage = encodeURIComponent(`Hi, I'd like to book a consultation at Vaidya Vrindavanam`);
const waLink = `https://wa.me/${PHONE_PRIMARY_RAW}?text=${waMessage}`;

const categoryLabels: Record<string, string> = {
  'health-tips': 'Health & Wellness',
  'treatment-guides': 'Treatment Guide',
  'seasonal-advice': 'Seasonal Advice',
  'patient-education': 'Patient Education',
};

const formattedDate = post.date.toLocaleDateString('en-IN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": post.title,
      "description": post.excerpt,
      "image": "https://vaidyavrindavanam.com/og-default.jpg",
      "author": {
        "@type": "Person",
        "name": post.author
      },
      "datePublished": post.date.toISOString(),
      "publisher": {
        "@type": "Organization",
        "name": "Vaidya Vrindavanam Ayurveda Hospital",
        "logo": {
          "@type": "ImageObject",
          "url": "https://vaidyavrindavanam.com/og-default.jpg"
        }
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://vaidyavrindavanam.com/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://vaidyavrindavanam.com/blog/" },
        { "@type": "ListItem", "position": 3, "name": post.title, "item": `https://vaidyavrindavanam.com/blog/${post.slug}/` }
      ]
    }
  ]
};
---

<BaseLayout
  title={post.title}
  description={post.excerpt}
  schema={schema}
  ogType="article"
  articlePublishedTime={post.date.toISOString()}
  articleAuthor={post.author}
>
  <!-- Article header -->
  <header class="article-header bg-brand-bg-alt">
    <div class="outer-pad">
      <nav class="breadcrumb-nav" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">—</span>
        <a href="/blog/">Blog</a>
      </nav>

      <div class="article-header-inner">
        <p class="category-label">{categoryLabels[post.category] ?? post.category.replace(/-/g, ' ')}</p>
        <h1 class="article-title">{post.title}</h1>
        <p class="article-excerpt">{post.excerpt}</p>
        <div class="byline">
          <span class="byline-author">{post.author}</span>
          <span class="byline-sep" aria-hidden="true">·</span>
          <time class="byline-date" datetime={post.date.toISOString()}>{formattedDate}</time>
        </div>
      </div>
    </div>
  </header>

  <!-- Article body -->
  <div class="bg-brand-bg">
    <div class="outer-pad article-container">

      <!-- Prose content -->
      <article class="article-prose" set:html={post.contentHTML}></article>

      <!-- Mid-article consultation CTA -->
      <aside class="consult-cta" aria-label="Book a consultation">
        <div class="consult-cta-inner">
          <p class="consult-cta-eyebrow">Vaidya Vrindavanam · Haripad, Kerala</p>
          <p class="consult-cta-heading">Ready to begin your healing?</p>
          <p class="consult-cta-sub">Book a personalised Ayurvedic consultation via WhatsApp — Mon to Sat, 9 am to 7 pm.</p>
          <div class="consult-cta-actions">
            <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Us
            </a>
            <a href="tel:+919074848705" class="btn-call">Call Now</a>
          </div>
        </div>
      </aside>

      <!-- Footer nav -->
      <nav class="article-footer-nav" aria-label="Article navigation">
        <a href="/blog/" class="back-link">← Back to Blog</a>
        <a href="/treatments/" class="treatments-link">Explore Treatments →</a>
      </nav>

    </div>
  </div>
</BaseLayout>

<style>
  /* ── Outer padding (fluid) ── */
  .outer-pad {
    padding-left: clamp(1.25rem, 4vw, 4rem);
    padding-right: clamp(1.25rem, 4vw, 4rem);
  }

  /* ── Header ── */
  .article-header {
    padding-top: 2rem;
    padding-bottom: 3.5rem;
  }

  .breadcrumb-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.625rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: oklch(71% 0.09 80 / 0.6);
    margin-bottom: 2.5rem;
  }

  .breadcrumb-nav a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb-nav a:hover {
    color: oklch(71% 0.09 80);
  }

  .breadcrumb-nav span[aria-hidden] {
    opacity: 0.35;
  }

  .article-header-inner {
    max-width: 760px;
  }

  .category-label {
    font-family: 'Inter Variable', Inter, system-ui, sans-serif;
    font-size: 0.5625rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #c8a96e;
    margin-bottom: 1rem;
  }

  .article-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 300;
    color: #e8e0d0;
    line-height: 1.15;
    letter-spacing: 0.01em;
    font-size: clamp(1.75rem, 5vw, 3rem);
    margin-bottom: 1rem;
  }

  .article-excerpt {
    font-family: 'Inter Variable', Inter, system-ui, sans-serif;
    font-size: 0.9375rem;
    color: #a09080;
    line-height: 1.7;
    max-width: 60ch;
    margin-bottom: 1.5rem;
  }

  .byline {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Inter Variable', Inter, system-ui, sans-serif;
    font-size: 0.75rem;
  }

  .byline-author {
    color: #c8a96e;
    letter-spacing: 0.04em;
  }

  .byline-sep {
    color: #8b8070;
    opacity: 0.5;
  }

  .byline-date {
    color: #8b8070;
  }

  /* ── Article body container ── */
  .article-container {
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
    padding-top: 3rem;
    padding-bottom: 5rem;
    display: grid;
    grid-template-columns: 1fr;
  }

  /* Reading column: constrained for comfort, left-aligned */
  .article-prose,
  .consult-cta,
  .article-footer-nav {
    max-width: 700px;
  }

  /* ── Prose ── */
  .article-prose :global(h2) {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 300;
    color: #c8a96e;
    letter-spacing: 0.02em;
    margin-top: 3rem;
    margin-bottom: 0.75rem;
    font-size: clamp(1.25rem, 3.5vw, 1.6rem);
    line-height: 1.25;
  }

  .article-prose :global(h3) {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 300;
    color: #c8a96e;
    margin-top: 2.25rem;
    margin-bottom: 0.6rem;
    font-size: clamp(1.05rem, 2.5vw, 1.25rem);
    line-height: 1.35;
  }

  .article-prose :global(p) {
    color: #a09080;
    font-size: 0.9375rem;
    line-height: 1.85;
    margin-bottom: 1.25rem;
  }

  .article-prose :global(ul) {
    list-style: none;
    padding: 0;
    margin-bottom: 1.5rem;
  }

  .article-prose :global(ul li) {
    color: #a09080;
    font-size: 0.9375rem;
    line-height: 1.75;
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.4rem;
  }

  .article-prose :global(ul li)::before {
    content: '—';
    position: absolute;
    left: 0;
    color: oklch(71% 0.09 80 / 0.4);
    font-size: 0.75rem;
    top: 0.15em;
  }

  .article-prose :global(ol) {
    padding-left: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .article-prose :global(ol li) {
    color: #a09080;
    font-size: 0.9375rem;
    line-height: 1.75;
    margin-bottom: 0.4rem;
    list-style-type: decimal;
    padding-left: 0.25rem;
  }

  .article-prose :global(strong) {
    color: #e8e0d0;
    font-weight: 600;
  }

  .article-prose :global(em) {
    color: #c0b090;
    font-style: italic;
  }

  .article-prose :global(a) {
    color: #c8a96e;
    text-decoration: none;
    border-bottom: 1px solid rgba(200, 169, 110, 0.3);
    transition: border-color 0.2s;
  }

  .article-prose :global(a:hover) {
    border-bottom-color: #c8a96e;
  }

  .article-prose :global(blockquote) {
    border: none;
    padding: 1.25rem 1.75rem;
    margin: 2.5rem 0;
    background: oklch(17% 0.028 145);
    color: #e8e0d0;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(1.05rem, 2.5vw, 1.25rem);
    font-style: italic;
    line-height: 1.65;
  }

  /* ── Consultation CTA block ── */
  .consult-cta {
    margin-top: 3.5rem;
    margin-bottom: 0.5rem;
  }

  .consult-cta-inner {
    background: oklch(17% 0.028 145);
    border: 1px solid rgba(200, 169, 110, 0.2);
    padding: clamp(1.5rem, 4vw, 2.25rem);
  }

  .consult-cta-eyebrow {
    font-family: 'Inter Variable', Inter, system-ui, sans-serif;
    font-size: 0.5625rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #c8a96e;
    margin-bottom: 0.75rem;
  }

  .consult-cta-heading {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 300;
    color: #e8e0d0;
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    line-height: 1.2;
    margin-bottom: 0.625rem;
    letter-spacing: 0.01em;
  }

  .consult-cta-sub {
    font-family: 'Inter Variable', Inter, system-ui, sans-serif;
    font-size: 0.8125rem;
    color: #a09080;
    line-height: 1.65;
    margin-bottom: 1.5rem;
    max-width: 52ch;
  }

  .consult-cta-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* ── Buttons ── */
  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #25D366;
    color: #fff;
    font-family: 'Inter Variable', Inter, system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.8125rem 1.25rem;
    transition: filter 0.2s;
    white-space: nowrap;
  }

  .btn-whatsapp:hover {
    filter: brightness(1.08);
  }

  .btn-call {
    display: inline-flex;
    align-items: center;
    border: 1px solid #c8a96e;
    color: #c8a96e;
    font-family: 'Inter Variable', Inter, system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.8125rem 1.25rem;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .btn-call:hover {
    background: #c8a96e;
    color: #0f1a0a;
  }

  /* ── Article footer nav ── */
  .article-footer-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(200, 169, 110, 0.18);
  }

  .back-link,
  .treatments-link {
    font-family: 'Inter Variable', Inter, system-ui, sans-serif;
    font-size: 0.625rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link {
    color: #c8a96e;
  }

  .back-link:hover {
    color: #e8e0d0;
  }

  .treatments-link {
    color: #8b8070;
  }

  .treatments-link:hover {
    color: #c8a96e;
  }
</style>
