---
interface Props {
  name: string;
  description: string;
  icon?: string;
  slug: string;
}

const { name, description, icon = '🌿', slug } = Astro.props;
---

<a href={`/treatments/${slug}`} class="block bg-brand-bg/60 border border-brand-gold-dim p-5 text-center hover:border-brand-gold transition-colors group">
  <div class="text-2xl mb-2 opacity-70">{icon}</div>
  <div class="text-sm text-text-primary font-semibold group-hover:text-brand-gold transition-colors">{name}</div>
  <div class="text-xs text-text-muted mt-2 leading-relaxed">{description}</div>
</a>
