---
interface Props {
  name: string;
  description: string;
  slug: string;
  imageUrl?: string;
  eager?: boolean;
}

const { name, description, slug, imageUrl, eager = false } = Astro.props;

// Sanity CDN image transforms: explicit WebP, responsive srcset
const optimizedUrl = imageUrl
  ? `${imageUrl}?w=600&h=400&fit=crop&fm=webp&q=75`
  : undefined;
const srcset = imageUrl
  ? `${imageUrl}?w=300&h=200&fit=crop&fm=webp&q=75 300w, ${imageUrl}?w=600&h=400&fit=crop&fm=webp&q=75 600w`
  : undefined;
---

<a href={`/treatments/${slug}`} class="block bg-brand-bg/60 border border-brand-gold-border hover:border-brand-gold transition-colors group overflow-hidden">
  <div class="aspect-[3/2] overflow-hidden bg-brand-bg-alt">
    {optimizedUrl
      ? <img
          src={optimizedUrl}
          srcset={srcset}
          sizes="(max-width: 640px) 50vw, 33vw"
          alt={`${name} Ayurveda treatment at Vaidya Vrindavanam, Haripad`}
          width="600"
          height="400"
          loading={eager ? 'eager' : 'lazy'}
          fetchpriority={eager ? 'high' : 'auto'}
          decoding={eager ? 'sync' : 'async'}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      : <div class="w-full h-full" aria-hidden="true" />
    }
  </div>
  <div class="p-4 text-center">
    <h3 class="text-sm text-text-primary font-semibold group-hover:text-brand-gold transition-colors">{name}</h3>
    <div class="text-xs text-text-muted mt-2 leading-relaxed line-clamp-3">{description}</div>
  </div>
</a>
