---
interface Props {
  name: string;
  qualification: string;
  title: string;
  image?: string;
  eager?: boolean;
}

const { name, qualification, title, image, eager = false } = Astro.props;
---

<div class="text-center">
  <div class="w-40 h-40 bg-brand-bg-alt border-2 border-brand-gold rounded-full mx-auto mb-3 flex items-center justify-center overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={name}
        width="160"
        height="160"
        loading={eager ? 'eager' : 'lazy'}
        decoding="async"
        class="w-full h-full object-cover object-top"
      />
    ) : (
      <span class="text-text-muted text-xs">Photo</span>
    )}
  </div>
  <div class="text-base text-text-primary font-semibold">{name}</div>
  <div class="text-xs text-brand-gold tracking-wide mt-1">{qualification}</div>
  <div class="text-xs text-text-muted mt-1">{title}</div>
</div>
