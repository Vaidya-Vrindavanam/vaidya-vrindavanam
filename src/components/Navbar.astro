---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Treatments', href: '/treatments' },
  { label: 'Packages', href: '/packages' },
  { label: 'Conditions', href: '/conditions' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
const whatsappUrl = "https://wa.me/919074848705?text=Hi%2C%20I'd%20like%20to%20book%20an%20appointment%20at%20Vaidya%20Vrindavanam";
---

<!-- Top Bar -->
<div class="bg-brand-bg-footer border-b border-brand-gold-border">
  <div class="max-w-7xl mx-auto px-4 py-2 flex flex-wrap items-center justify-center gap-x-6 gap-y-1 text-xs text-text-muted">
    <a href="tel:+919074848705" class="hover:text-brand-gold transition-colors">
      📞 +91 90748 48705
    </a>
    <span class="hidden sm:inline text-text-subtle">|</span>
    <a href="mailto:info@vaidyavrindavanam.com" class="hover:text-brand-gold transition-colors">
      ✉ info@vaidyavrindavanam.com
    </a>
    <span class="hidden sm:inline text-text-subtle">|</span>
    <span>Mon–Sat: 9AM–12PM &amp; 4PM–7PM</span>
  </div>
</div>

<!-- Main Navbar -->
<nav id="main-nav" class="sticky top-0 z-50 bg-brand-bg/95 backdrop-blur-md border-b border-brand-gold-border">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="flex flex-col leading-tight">
      <span class="font-display text-xl md:text-2xl text-brand-gold tracking-wide">VAIDYA VRINDAVANAM</span>
      <span class="text-xs text-text-muted tracking-widest uppercase">Ayurveda Hospital · Haripad</span>
    </a>

    <!-- Desktop Nav Links -->
    <ul class="hidden lg:flex items-center gap-1">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        return (
          <li>
            <a
              href={link.href}
              class={`px-3 py-2 text-sm font-body transition-colors rounded-sm ${
                isActive
                  ? 'text-brand-gold border-b border-brand-gold'
                  : 'text-text-secondary hover:text-text-primary'
              }`}
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>

    <!-- Book Now Button (Desktop) -->
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="hidden lg:inline-flex items-center gap-2 bg-brand-gold text-brand-bg text-xs font-body font-semibold tracking-widest uppercase px-5 py-2.5 rounded-sm hover:bg-brand-gold/90 transition-colors"
    >
      BOOK NOW
    </a>

    <!-- Hamburger (Mobile) -->
    <button
      id="menu-open"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="lg:hidden flex flex-col gap-1.5 p-2"
    >
      <span class="w-6 h-0.5 bg-brand-gold block"></span>
      <span class="w-6 h-0.5 bg-brand-gold block"></span>
      <span class="w-6 h-0.5 bg-brand-gold block"></span>
    </button>
  </div>
</nav>

<!-- Mobile Full-Screen Overlay -->
<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  class="fixed inset-0 z-[100] bg-brand-bg flex flex-col items-center justify-center gap-8 hidden"
>
  <!-- Close Button -->
  <button
    id="menu-close"
    aria-label="Close menu"
    class="absolute top-5 right-5 text-brand-gold text-4xl leading-none"
  >
    &times;
  </button>

  <!-- Logo inside overlay -->
  <div class="text-center mb-4">
    <div class="font-display text-2xl text-brand-gold tracking-wide">VAIDYA VRINDAVANAM</div>
    <div class="text-xs text-text-muted tracking-widest uppercase mt-1">Ayurveda Hospital · Haripad</div>
  </div>

  <!-- Mobile Nav Links -->
  <ul class="flex flex-col items-center gap-6">
    {navLinks.map((link) => {
      const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
      return (
        <li>
          <a
            href={link.href}
            class={`font-display text-2xl transition-colors ${
              isActive ? 'text-brand-gold' : 'text-text-primary hover:text-brand-gold'
            }`}
          >
            {link.label}
          </a>
        </li>
      );
    })}
  </ul>

  <!-- Book Now (Mobile) -->
  <a
    href={whatsappUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-4 bg-brand-gold text-brand-bg text-sm font-body font-semibold tracking-widest uppercase px-8 py-3 rounded-sm hover:bg-brand-gold/90 transition-colors"
  >
    BOOK NOW
  </a>
</div>

<script>
  const openBtn = document.getElementById('menu-open');
  const closeBtn = document.getElementById('menu-close');
  const mobileMenu = document.getElementById('mobile-menu');

  openBtn?.addEventListener('click', () => {
    mobileMenu?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    openBtn.setAttribute('aria-expanded', 'true');
  });

  const closeMenu = () => {
    mobileMenu?.classList.add('hidden');
    document.body.style.overflow = '';
    openBtn?.setAttribute('aria-expanded', 'false');
  };

  closeBtn?.addEventListener('click', closeMenu);

  // Close on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
