---
interface Props {
  items: { question: string; answer: string }[];
}

const { items } = Astro.props;
---

<div class="space-y-2 max-w-2xl mx-auto">
  {items.map((item) => (
    <details class="group border border-brand-gold-dim bg-brand-bg">
      <summary class="flex justify-between items-center gap-4 cursor-pointer list-none px-5 py-4 text-sm font-semibold text-text-primary">
        <span>{item.question}</span>
        <span class="relative w-3 h-3 shrink-0" aria-hidden="true">
          <span class="absolute inset-x-0 top-1/2 -translate-y-1/2 h-px bg-brand-gold"></span>
          <span class="absolute inset-y-0 left-1/2 -translate-x-1/2 w-px bg-brand-gold transition-transform duration-300 ease-[cubic-bezier(0.25,1,0.5,1)] group-open:rotate-90"></span>
        </span>
      </summary>
      <div class="px-5 pb-4 text-sm text-text-secondary leading-relaxed">
        {item.answer}
      </div>
    </details>
  ))}
</div>

<style>
  /* Hide the default disclosure marker across browsers so our + / − glyph is the sole signal. */
  details > summary::-webkit-details-marker { display: none; }
  details > summary::marker { content: ''; }
</style>
