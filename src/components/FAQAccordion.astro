---
interface Props {
  items: { question: string; answer: string }[];
}

const { items } = Astro.props;
---

<div class="space-y-2 max-w-2xl mx-auto">
  {items.map((item, i) => (
    <details class="group border border-brand-gold-dim bg-brand-bg">
      <summary class="flex justify-between items-center cursor-pointer px-5 py-4 text-sm font-semibold text-text-primary">
        <span>{item.question}</span>
        <span class="text-brand-gold transition-transform group-open:rotate-45">+</span>
      </summary>
      <div class="px-5 pb-4 text-sm text-text-secondary leading-relaxed">
        {item.answer}
      </div>
    </details>
  ))}
</div>
