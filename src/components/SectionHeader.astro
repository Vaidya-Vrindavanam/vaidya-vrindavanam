---
interface Props {
  label: string;
  heading: string;
  subtitle?: string;
}

const { label, heading, subtitle } = Astro.props;
---

<div class="text-center mb-8">
  <div class="text-[8px] tracking-[4px] uppercase text-brand-gold">{label}</div>
  <h2 class="text-2xl md:text-3xl text-text-primary font-display font-light mt-2 tracking-wide">{heading}</h2>
  {subtitle && <p class="text-sm text-text-muted mt-2">{subtitle}</p>}
  <div class="w-8 h-px bg-brand-gold mx-auto mt-4"></div>
</div>
