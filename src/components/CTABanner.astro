---
import { WA_DEFAULT, PHONE_SECONDARY_RAW } from '../config/contact';
---

<section class="py-16 px-6 bg-brand-bg text-center border-t border-brand-gold-dim">
  <h2 class="text-2xl md:text-3xl text-text-primary font-display font-light tracking-wide">Begin Your Healing Journey</h2>
  <p class="text-sm text-text-muted mt-3 mb-8">Book a consultation via WhatsApp or visit us in Haripad</p>
  <div class="flex gap-3 justify-center flex-wrap">
    <a
      href={WA_DEFAULT}
      target="_blank"
      rel="noopener noreferrer"
      class="bg-brand-whatsapp text-white px-7 py-3 text-xs font-bold tracking-widest"
    >
      WHATSAPP US
    </a>
    <a
      href={`tel:+${PHONE_SECONDARY_RAW}`}
      class="bg-brand-gold text-brand-bg px-7 py-3 text-xs font-bold tracking-widest"
    >
      CALL NOW
    </a>
  </div>
</section>
