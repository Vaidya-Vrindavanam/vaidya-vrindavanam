---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description: string;
  schema?: object;
  ogType?: string;
  articlePublishedTime?: string;
  articleAuthor?: string;
  lcpImage?: string;
}

const { title, description, schema, ogType, articlePublishedTime, articleAuthor, lcpImage } = Astro.props;

const lcpSrcset = lcpImage
  ? `${lcpImage}?w=240&h=160&fit=crop&auto=format&q=65 240w, ${lcpImage}?w=480&h=320&fit=crop&auto=format&q=65 480w, ${lcpImage}?w=720&h=480&fit=crop&auto=format&q=65 720w`
  : undefined;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Preconnect to Sanity CDN for faster image loads -->
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    {lcpSrcset && (
      <link
        rel="preload"
        as="image"
        imagesrcset={lcpSrcset}
        imagesizes="(max-width: 640px) 50vw, 33vw"
        fetchpriority="high"
      />
    )}
    <SEO
      title={title}
      description={description}
      schema={schema}
      ogType={ogType}
      articlePublishedTime={articlePublishedTime}
      articleAuthor={articleAuthor}
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
    <Analytics />
    <!-- Google Analytics — deferred until after page load -->
    <script>
      window.addEventListener('load', function() {
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-48TMD9CGFK';
        s.async = true;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-48TMD9CGFK', { send_page_view: true });
      });
    </script>
  </body>
</html>
